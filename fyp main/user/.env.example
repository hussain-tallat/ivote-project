# Google Cloud Translation API - DO NOT COMMIT TO GIT!

# Get your API key from: https://console.cloud.google.com/apis/credentials
# 1. Go to Google Cloud Console
# 2. Create a new project or select existing
# 3. Enable "Cloud Translation API"
# 4. Create credentials (API Key)
# 5. Copy the API key and paste it below

REACT_APP_GOOGLE_TRANSLATE_API_KEY=your_api_key_here

# Disable source map processing to avoid warnings from third-party packages
GENERATE_SOURCEMAP=false
